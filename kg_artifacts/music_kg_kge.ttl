ns2:activeFrom a owl:DatatypeProperty ;
    rdfs:range xsd:gYear ;
    owl:equivalentProperty ns1:P2031 .

ns2:albumRating a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    skos:relatedMatch ns1:P444 .

ns2:birthYear a owl:DatatypeProperty ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf ns1:P569 .

ns2:collaboratedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:domain <http://example.org/music/Artist> ;
    rdfs:range <http://example.org/music/Artist> ;
    skos:relatedMatch ns1:P175 .

ns2:foundedYear a owl:DatatypeProperty ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf ns1:P571 .

ns2:hasGenre a owl:ObjectProperty ;
    rdfs:range <http://example.org/music/Genre> ;
    owl:equivalentProperty ns1:P136 .

ns2:influencedBy a owl:ObjectProperty ;
    rdfs:domain <http://example.org/music/Artist> ;
    rdfs:range <http://example.org/music/Artist> ;
    owl:equivalentProperty ns1:P737 .

ns2:originatesFrom a owl:ObjectProperty ;
    rdfs:range <http://example.org/music/Country> ;
    owl:equivalentProperty ns1:P495 .

ns2:partOfGenre a owl:ObjectProperty ;
    skos:relatedMatch ns1:P279 .

ns2:releaseYear a owl:DatatypeProperty ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf ns1:P577 .

ns2:releasedAlbum a owl:ObjectProperty ;
    rdfs:domain <http://example.org/music/Artist> ;
    rdfs:range <http://example.org/music/Album> ;
    rdfs:subPropertyOf ns1:P358 ;
    owl:inverseOf ns2:producedBy .

ns2:signedTo a owl:ObjectProperty ;
    rdfs:domain <http://example.org/music/Artist> ;
    rdfs:range <http://example.org/music/RecordLabel> ;
    owl:equivalentProperty ns1:P264 .

ns2:wonAward a owl:ObjectProperty ;
    rdfs:range <http://example.org/music/Award> ;
    owl:equivalentProperty ns1:P166 .

