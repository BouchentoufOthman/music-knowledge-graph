prop:activeFrom a owl:DatatypeProperty ;
    rdfs:label "Year career started" ;
    rdfs:range xsd:gYear .

prop:albumRating a owl:DatatypeProperty ;
    rdfs:label "Critical rating 0-10" ;
    rdfs:range xsd:decimal .

prop:birthYear a owl:DatatypeProperty ;
    rdfs:label "Year of birth" ;
    rdfs:range xsd:gYear .

prop:collaboratedWith a owl:ObjectProperty ;
    rdfs:label "Artist collaborated with another artist" .

prop:foundedYear a owl:DatatypeProperty ;
    rdfs:label "Year label founded" ;
    rdfs:range xsd:gYear .

prop:hasGenre a owl:ObjectProperty ;
    rdfs:label "Artist or album has genre" .

prop:influencedBy a owl:ObjectProperty ;
    rdfs:label "Artist was influenced by another artist" .

prop:originatesFrom a owl:ObjectProperty ;
    rdfs:label "Artist originates from country" .

prop:partOfGenre a owl:ObjectProperty ;
    rdfs:label "Genre is a subgenre of another genre" .

prop:producedBy a owl:ObjectProperty ;
    rdfs:label "Album produced by artist" .

prop:releaseYear a owl:DatatypeProperty ;
    rdfs:label "Year album released" ;
    rdfs:range xsd:gYear .

prop:releasedAlbum a owl:ObjectProperty ;
    rdfs:label "Artist released album" .

prop:signedTo a owl:ObjectProperty ;
    rdfs:label "Artist signed to record label" .

prop:wonAward a owl:ObjectProperty ;
    rdfs:label "Artist won award" .

