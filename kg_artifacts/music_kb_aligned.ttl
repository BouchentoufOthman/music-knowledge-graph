prop:producedBy a owl:ObjectProperty ;
    rdfs:label "Album produced by artist" ;
    rdfs:comment "Aligned to wdt:P175 (performer) via subProperty. P175 'performer' is the closest match for album->artist. prop:producedBy is narrower (emphasises production role)." ;
    rdfs:domain mus:Album ;
    rdfs:range mus:Artist ;
    rdfs:subPropertyOf wdt:P175 .

