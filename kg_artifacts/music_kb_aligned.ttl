prop:activeFrom a owl:DatatypeProperty ;
    rdfs:label "Year career started" ;
    rdfs:comment "Aligned to wdt:P2031 (work period (start)) via equivalent. P2031 'work period (start)' directly matches prop:activeFrom." ;
    rdfs:range xsd:gYear ;
    owl:equivalentProperty wdt:P2031 .

prop:albumRating a owl:DatatypeProperty ;
    rdfs:label "Critical rating 0-10" ;
    rdfs:comment "Aligned to wdt:P444 (review score) via related. P444 stores review scores as strings; prop:albumRating is a typed decimal. Related but different datatype semantics." ;
    rdfs:range xsd:decimal ;
    skos:relatedMatch wdt:P444 .

prop:birthYear a owl:DatatypeProperty ;
    rdfs:label "Year of birth" ;
    rdfs:comment "Aligned to wdt:P569 (date of birth) via subProperty. P569 is a full timestamp; prop:birthYear is year-only (coarser granularity)." ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf wdt:P569 .

prop:collaboratedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "Artist collaborated with another artist" ;
    rdfs:comment "Aligned to wdt:P175 (performer) via related. P175 links a work to a performer, not artist-to-artist. No exact Wikidata equivalent exists for direct collaboration." ;
    rdfs:domain mus:Artist ;
    rdfs:range mus:Artist ;
    skos:relatedMatch wdt:P175 .

prop:foundedYear a owl:DatatypeProperty ;
    rdfs:label "Year label founded" ;
    rdfs:comment "Aligned to wdt:P571 (inception) via subProperty. P571 'inception' is a full timestamp; prop:foundedYear is year-only." ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf wdt:P571 .

prop:hasGenre a owl:ObjectProperty ;
    rdfs:label "Artist or album has genre" ;
    rdfs:comment "Aligned to wdt:P136 (genre) via equivalent. P136 'genre' maps directly to prop:hasGenre. Both assert the genre of a musical work or artist." ;
    rdfs:range mus:Genre ;
    owl:equivalentProperty wdt:P136 .

prop:influencedBy a owl:ObjectProperty ;
    rdfs:label "Artist was influenced by another artist" ;
    rdfs:comment "Aligned to wdt:P737 (influenced by) via equivalent. P737 'influenced by' is a direct semantic match to prop:influencedBy." ;
    rdfs:domain mus:Artist ;
    rdfs:range mus:Artist ;
    owl:equivalentProperty wdt:P737 .

prop:originatesFrom a owl:ObjectProperty ;
    rdfs:label "Artist originates from country" ;
    rdfs:comment "Aligned to wdt:P495 (country of origin) via equivalent. P495 'country of origin' matches prop:originatesFrom for both artists and albums." ;
    rdfs:range mus:Country ;
    owl:equivalentProperty wdt:P495 .

prop:partOfGenre a owl:ObjectProperty ;
    rdfs:label "Genre is a subgenre of another genre" ;
    rdfs:comment "Aligned to wdt:P279 (subclass of) via related. P279 is the generic subclass relation; prop:partOfGenre is genre-specific." ;
    skos:relatedMatch wdt:P279 .

prop:releaseYear a owl:DatatypeProperty ;
    rdfs:label "Year album released" ;
    rdfs:comment "Aligned to wdt:P577 (publication date) via subProperty. P577 is a full timestamp; prop:releaseYear stores year only." ;
    rdfs:range xsd:gYear ;
    rdfs:subPropertyOf wdt:P577 .

prop:releasedAlbum a owl:ObjectProperty ;
    rdfs:label "Artist released album" ;
    rdfs:comment "Aligned to wdt:P358 (discography) via subProperty. P358 'discography' groups all releases; prop:releasedAlbum is narrower (albums only)." ;
    rdfs:domain mus:Artist ;
    rdfs:range mus:Album ;
    rdfs:subPropertyOf wdt:P358 ;
    owl:inverseOf prop:producedBy .

prop:signedTo a owl:ObjectProperty ;
    rdfs:label "Artist signed to record label" ;
    rdfs:comment "Aligned to wdt:P264 (record label) via equivalent. P264 'record label' is the canonical Wikidata property for artist-label affiliation." ;
    rdfs:domain mus:Artist ;
    rdfs:range mus:RecordLabel ;
    owl:equivalentProperty wdt:P264 .

prop:wonAward a owl:ObjectProperty ;
    rdfs:label "Artist won award" ;
    rdfs:comment "Aligned to wdt:P166 (award received) via equivalent. P166 'award received' is the standard Wikidata property for winning an award. Semantically identical." ;
    rdfs:range mus:Award ;
    owl:equivalentProperty wdt:P166 .

